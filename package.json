{
  "name": "openfb-plugin",
  "publisher": "RITMS",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.3",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openfb.plugin.showSysDiagram",
        "title": "%command.showSysDiagram%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceFilename =~ /\\.sys$/",
          "command": "openfb.plugin.showSysDiagram",
          "group": "openfb@1"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "openfb.fbLibraryPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.fbLibraryPaths%",
          "scope": "window"
        },
        "openfb.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "%config.host%",
          "scope": "window"
        },
        "openfb.port": {
          "type": "number",
          "default": 61499,
          "description": "%config.port%",
          "scope": "window"
        },
        "openfb.deployTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "%config.deployTimeoutMs%",
          "scope": "window"
        },
        "openfb.uiLanguage": {
          "type": "string",
          "enum": [
            "ru",
            "en"
          ],
          "enumDescriptions": [
            "%config.uiLanguage.ru%",
            "%config.uiLanguage.en%"
          ],
          "default": "en",
          "description": "%config.uiLanguage%",
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "typecheck": "tsc -p ./ --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "compile": "npm run typecheck && node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^24.10.12",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.3.4"
  }
}
