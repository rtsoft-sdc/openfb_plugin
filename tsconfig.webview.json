{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "node",
    "declaration": false,
    "sourceMap": false,
    "outDir": "out/webview",
    "rootDir": "src",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/webview/**/*", "src/colorScheme.ts"]
}
